PORT=3002

# InfluxDB 3.0 Configuration
INFLUX_HOST=localhost
INFLUX_PORT=8181
INFLUX_TOKEN=your_influxdb_token_here
INFLUX_DATABASE=cow

# JWT
JWT_SECRET=change_me_in_production
JWT_EXPIRES_IN=7d

# CORS (leave unset in development, set to frontend URL in production)
CORS_ORIGIN=

# MQTT Broker Connection
MQTT_PROTOCOL=mqtt
MQTT_HOST=127.0.0.1
MQTT_PORT=1883
MQTT_USERNAME=
MQTT_PASSWORD=
